# Database
# For Prisma Postgres, use the pooled URL here for runtime queries.
DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"

# Use the direct URL for migrations, Prisma Studio, and other CLI commands.
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://opencode.cash"
NEXTAUTH_SECRET="your-secret-key-here" # Generate with: openssl rand -base64 32

# Twitter/X OAuth 2.0
# Get these from https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
